# Build Stage
FROM node:18-alpine AS builder
WORKDIR /app

ARG INTERNAL_API_URL=http://backend:8000/api
ARG NEXT_PUBLIC_API_URL
ARG NEXT_PUBLIC_SITE_URL
ARG NEXT_PUBLIC_COMPANY_NAME
ARG NEXT_PUBLIC_COMPANY_DIVISION
ARG NEXT_PUBLIC_COMPANY_FULL_NAME
ARG NEXT_PUBLIC_COMPANY_TAGLINE
ARG NEXT_PUBLIC_COMPANY_DESCRIPTION
ARG NEXT_PUBLIC_WHATSAPP_NUMBER
ARG NEXT_PUBLIC_PHONE_NUMBER
ARG NEXT_PUBLIC_COMPANY_EMAIL
ARG NEXT_PUBLIC_COMPANY_STREET_ADDRESS
ARG NEXT_PUBLIC_COMPANY_CITY
ARG NEXT_PUBLIC_COMPANY_COUNTRY
ARG NEXT_PUBLIC_COMPANY_POSTAL_CODE
ARG NEXT_PUBLIC_COMPANY_OPENING_HOURS
ARG NEXT_PUBLIC_SERVICE_AREA
ARG NEXT_PUBLIC_LOCALE
ARG NEXT_PUBLIC_TIME_ZONE
ARG NEXT_PUBLIC_CURRENCY
ARG NEXT_PUBLIC_ACCEPTED_CURRENCIES
ARG NEXT_PUBLIC_COMPANY_LATITUDE
ARG NEXT_PUBLIC_COMPANY_LONGITUDE
ARG NEXT_PUBLIC_GOOGLE_MAPS_PLACE_QUERY
ARG NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY
ARG NEXT_PUBLIC_LINKEDIN_URL
ARG NEXT_PUBLIC_INSTAGRAM_URL
ARG NEXT_PUBLIC_FACEBOOK_URL
ARG NEXT_PUBLIC_TIKTOK_URL
ARG NEXT_PUBLIC_TWITTER_URL
ARG NEXT_PUBLIC_TWITTER_HANDLE
ARG NEXT_PUBLIC_DEFAULT_KEYWORDS

ENV INTERNAL_API_URL=$INTERNAL_API_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_SITE_URL=$NEXT_PUBLIC_SITE_URL
ENV NEXT_PUBLIC_COMPANY_NAME=$NEXT_PUBLIC_COMPANY_NAME
ENV NEXT_PUBLIC_COMPANY_DIVISION=$NEXT_PUBLIC_COMPANY_DIVISION
ENV NEXT_PUBLIC_COMPANY_FULL_NAME=$NEXT_PUBLIC_COMPANY_FULL_NAME
ENV NEXT_PUBLIC_COMPANY_TAGLINE=$NEXT_PUBLIC_COMPANY_TAGLINE
ENV NEXT_PUBLIC_COMPANY_DESCRIPTION=$NEXT_PUBLIC_COMPANY_DESCRIPTION
ENV NEXT_PUBLIC_WHATSAPP_NUMBER=$NEXT_PUBLIC_WHATSAPP_NUMBER
ENV NEXT_PUBLIC_PHONE_NUMBER=$NEXT_PUBLIC_PHONE_NUMBER
ENV NEXT_PUBLIC_COMPANY_EMAIL=$NEXT_PUBLIC_COMPANY_EMAIL
ENV NEXT_PUBLIC_COMPANY_STREET_ADDRESS=$NEXT_PUBLIC_COMPANY_STREET_ADDRESS
ENV NEXT_PUBLIC_COMPANY_CITY=$NEXT_PUBLIC_COMPANY_CITY
ENV NEXT_PUBLIC_COMPANY_COUNTRY=$NEXT_PUBLIC_COMPANY_COUNTRY
ENV NEXT_PUBLIC_COMPANY_POSTAL_CODE=$NEXT_PUBLIC_COMPANY_POSTAL_CODE
ENV NEXT_PUBLIC_COMPANY_OPENING_HOURS=$NEXT_PUBLIC_COMPANY_OPENING_HOURS
ENV NEXT_PUBLIC_SERVICE_AREA=$NEXT_PUBLIC_SERVICE_AREA
ENV NEXT_PUBLIC_LOCALE=$NEXT_PUBLIC_LOCALE
ENV NEXT_PUBLIC_TIME_ZONE=$NEXT_PUBLIC_TIME_ZONE
ENV NEXT_PUBLIC_CURRENCY=$NEXT_PUBLIC_CURRENCY
ENV NEXT_PUBLIC_ACCEPTED_CURRENCIES=$NEXT_PUBLIC_ACCEPTED_CURRENCIES
ENV NEXT_PUBLIC_COMPANY_LATITUDE=$NEXT_PUBLIC_COMPANY_LATITUDE
ENV NEXT_PUBLIC_COMPANY_LONGITUDE=$NEXT_PUBLIC_COMPANY_LONGITUDE
ENV NEXT_PUBLIC_GOOGLE_MAPS_PLACE_QUERY=$NEXT_PUBLIC_GOOGLE_MAPS_PLACE_QUERY
ENV NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=$NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY
ENV NEXT_PUBLIC_LINKEDIN_URL=$NEXT_PUBLIC_LINKEDIN_URL
ENV NEXT_PUBLIC_INSTAGRAM_URL=$NEXT_PUBLIC_INSTAGRAM_URL
ENV NEXT_PUBLIC_FACEBOOK_URL=$NEXT_PUBLIC_FACEBOOK_URL
ENV NEXT_PUBLIC_TIKTOK_URL=$NEXT_PUBLIC_TIKTOK_URL
ENV NEXT_PUBLIC_TWITTER_URL=$NEXT_PUBLIC_TWITTER_URL
ENV NEXT_PUBLIC_TWITTER_HANDLE=$NEXT_PUBLIC_TWITTER_HANDLE
ENV NEXT_PUBLIC_DEFAULT_KEYWORDS=$NEXT_PUBLIC_DEFAULT_KEYWORDS

COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

# Production Stage
FROM node:18-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production

ARG INTERNAL_API_URL=http://backend:8000/api
ARG NEXT_PUBLIC_API_URL
ARG NEXT_PUBLIC_SITE_URL
ARG NEXT_PUBLIC_COMPANY_NAME
ARG NEXT_PUBLIC_COMPANY_DIVISION
ARG NEXT_PUBLIC_COMPANY_FULL_NAME
ARG NEXT_PUBLIC_COMPANY_TAGLINE
ARG NEXT_PUBLIC_COMPANY_DESCRIPTION
ARG NEXT_PUBLIC_WHATSAPP_NUMBER
ARG NEXT_PUBLIC_PHONE_NUMBER
ARG NEXT_PUBLIC_COMPANY_EMAIL
ARG NEXT_PUBLIC_COMPANY_STREET_ADDRESS
ARG NEXT_PUBLIC_COMPANY_CITY
ARG NEXT_PUBLIC_COMPANY_COUNTRY
ARG NEXT_PUBLIC_COMPANY_POSTAL_CODE
ARG NEXT_PUBLIC_COMPANY_OPENING_HOURS
ARG NEXT_PUBLIC_SERVICE_AREA
