ENV NEXT_PUBLIC_CURRENCY=$NEXT_PUBLIC_CURRENCY
ENV NEXT_PUBLIC_ACCEPTED_CURRENCIES=$NEXT_PUBLIC_ACCEPTED_CURRENCIES
