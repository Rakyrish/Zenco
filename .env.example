# =============================================================================
# ZENCO SYSTEMS LTD – CHEMICAL DIVISION
# Environment Variables Template — Copy to .env and fill in values
# =============================================================================

# ─── Django ──────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=your-super-secret-django-key-change-this-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,zencosystems.co.ke,www.zencosystems.co.ke
DJANGO_SETTINGS_MODULE=config.settings.production

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_NAME=zenco_db
DB_USER=zenco_user
DB_PASSWORD=strong_database_password_here
DB_HOST=postgres
DB_PORT=5432

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key_here
DEFAULT_FROM_EMAIL=noreply@zencosystems.co.ke
ADMIN_EMAIL=admin@zencosystems.co.ke
INQUIRY_NOTIFICATION_EMAIL=inquiries@zencosystems.co.ke

# ─── Frontend (Next.js) ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://zencosystems.co.ke/api
NEXT_PUBLIC_SITE_URL=https://zencosystems.co.ke
NEXT_PUBLIC_WHATSAPP_NUMBER=+254700000000
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=your_google_maps_api_key
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ─── Media & Storage ─────────────────────────────────────────────────────────
MEDIA_URL=/media/
STATIC_URL=/static/
# AWS S3 (optional for production)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=

# ─── Security ────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://zencosystems.co.ke,https://www.zencosystems.co.ke
CSRF_TRUSTED_ORIGINS=https://zencosystems.co.ke,https://www.zencosystems.co.ke
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── Rate Limiting ───────────────────────────────────────────────────────────
INQUIRY_RATE_LIMIT=10/h
API_RATE_LIMIT=100/h
